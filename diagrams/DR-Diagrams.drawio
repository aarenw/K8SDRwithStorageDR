        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Phase 1: Decision (0-5 min) — Orange                -->
        <!-- ═══════════════════════════════════════════════════ -->
        <mxCell id="P1" value="&lt;b style=&apos;color:#151515&apos;&gt;Phase 1&lt;/b&gt;&lt;br&gt;&lt;span style=&apos;color:#3C3F42&apos;&gt;故障确认&lt;br&gt;0-5 min&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF7E7;strokeColor=#EC7A08;strokeWidth=2;fontSize=10;align=center;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="0" y="130" width="72" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="m1" value="Launch DR-Failover-Master" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;fontSize=10;strokeColor=#3C3F42;fontColor=#151515;" edge="1" parent="1">
