          <mxGeometry relative="1" as="geometry"><mxPoint x="380" y="160" as="sourcePoint"/><mxPoint x="150" y="160" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="确认: YES-FAILOVER" style="endArrow=block;endFill=1;html=1;strokeWidth=1.5;fontSize=10;strokeColor=#3C3F42;fontColor=#151515;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="150" y="180" as="sourcePoint"/><mxPoint x="380" y="180" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- Phase 2: Storage (5-10 min) — Yellow                -->
