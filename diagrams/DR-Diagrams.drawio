        <mxCell id="ph6" value="&lt;b style=&apos;color:#151515&apos;&gt;GSLB / GTM&lt;/b&gt;&lt;br&gt;&lt;span style=&apos;color:#6A6E73;font-size:9px&apos;&gt;DNS API&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#6A6E73;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1160" y="55" width="140" height="50" as="geometry"/>
