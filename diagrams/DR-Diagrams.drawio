        <mxCell id="rto" value="&lt;table style=&apos;font-size:11px;border-collapse:collapse;color:#151515;width:100%&apos;&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 1 故障确认&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;5 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 2 存储切换&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;5 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 3 FC 扫描&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;5 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 4 VM+容器恢复&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;35 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 5 网络切换&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;5 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;Phase 6 验收&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:4px 10px;border-bottom:1px solid #D2D2D2&apos;&gt;5 min&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td style=&apos;padding:6px 10px;font-weight:bold;color:#CC0000&apos;&gt;Total RTO&lt;/td&gt;&lt;td style=&apos;text-align:right;padding:6px 10px;font-weight:bold;color:#CC0000&apos;&gt;≤ 60 min&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#D2D2D2;strokeWidth=1;fontSize=11;align=left;verticalAlign=top;spacingTop=5;arcSize=4;" vertex="1" parent="1">
